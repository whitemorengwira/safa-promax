# ===================================================================
# .gitignore — protects secrets and excludes build artefacts
# ===================================================================

# --- SECRETS: never commit these ---
.env
.env.local
.env*.local
.env.production
docs/visual-qa/cms-dev-*.log
*.pem
*.key

# --- Dependencies ---
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# --- Next.js build output ---
/.next/
/out/
/build
next-env.d.ts

# --- Production ---
/dist

# --- Misc / OS ---
.DS_Store
*.pem
Thumbs.db
desktop.ini

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
docs/visual-qa/dev-*.log

# --- Local env files & editor ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp

# --- Vercel ---
.vercel

# --- TypeScript ---
*.tsbuildinfo

# --- Downloaded Getty originals (host on R2 instead of committing) ---
/public/images/getty-originals/

.vercel
