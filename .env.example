# ===================================================================
# SA FILM ACADEMY — ENVIRONMENT TEMPLATE (.env.example)
# ===================================================================
# This file IS safe to commit. It documents which variables the app
# needs WITHOUT exposing any secret values. To set up locally:
#   1. Copy this file to .env.local
#   2. Fill in the real values (kept out of git by .gitignore)
# ===================================================================

# --- AI MODEL PROVIDERS ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- SUPABASE (PRIMARY) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# --- SUPABASE (SAM DOSSIER) ---
SAM_DOSSIER_SUPABASE_URL=
SAM_DOSSIER_SUPABASE_ANON_KEY=
SAM_DOSSIER_SUPABASE_SERVICE_ROLE_KEY=
SAM_DOSSIER_SUPABASE_PASSWORD=
SAM_DOSSIER_PUBLISHABLE_KEY=
SAM_DOSSIER_SECRET_KEY=

# --- CLOUDFLARE R2 ---
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCOUNT_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_TOKEN=
CLOUDFLARE_R2_ADMIN_TOKEN=
